{
  "name": "@gridix/types",
  "version": "0.0.0",
  "private": true,
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": "./src/index.ts",
    "./database": "./src/database.ts",
    "./entities": "./src/entities.ts"
  },
  "scripts": {
    "typecheck": "tsc --noEmit",
    "generate:types": "npx supabase gen types typescript --project-id $(grep VITE_SUPABASE_PROJECT_ID ../../.env | cut -d '=' -f2) > src/database.ts"
  },
  "devDependencies": {
    "@gridix/config": "workspace:*",
    "typescript": "^5.9.3"
  }
}
