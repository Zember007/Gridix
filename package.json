{
  "name": "gridix-monorepo",
  "private": true,
  "version": "0.0.0",
  "scripts": {
    "dev": "pnpm turbo run dev",
    "build": "pnpm turbo run build",
    "lint": "pnpm turbo run lint",
    "format": "prettier . --write",
    "format:check": "lint-staged --diff=origin/dev --allow-empty",
    "typecheck": "pnpm turbo run typecheck",
    "clean": "pnpm turbo run clean",
    "dev:main": "pnpm --filter @gridix/main dev",
    "dev:agent": "pnpm --filter @gridix/agent-cabinet dev",
    "dev:auth": "pnpm --filter @gridix/auth dev",
    "prepare": "husky",
    "translate": "node scripts/translate.mjs",
    "translate:dry-run": "node scripts/translate.mjs --dry-run"
  },
  "devDependencies": {
    "eslint-config-prettier": "^10.1.8",
    "fs-extra": "^11.3.3",
    "google-translate-api-x": "^10.7.2",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "prettier-plugin-tailwindcss": "^0.7.2",
    "turbo": "^2.3.3"
  },
  "packageManager": "pnpm@9.15.4",
  "engines": {
    "node": ">=18"
  },
  "lint-staged": {
    "*.{js,jsx,ts,tsx,mjs,cjs,json,md,yml,yaml,css,scss,html}": "prettier --check"
  }
}
