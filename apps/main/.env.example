

# -----------------------------------------------------------------------------
# SUPABASE CONFIGURATION (REQUIRED)
# -----------------------------------------------------------------------------
# Project ID from Supabase Dashboard → Settings → General
# Used for: type generation, supabase CLI commands
VITE_SUPABASE_PROJECT_ID="your-dev-project-id"

# Supabase URL from Dashboard → Settings → API → Project URL
VITE_SUPABASE_URL="https://your-dev-project-id.supabase.co"

# Anon/Public key from Dashboard → Settings → API → Project API Keys → anon/public
# This is safe to expose in frontend code
VITE_SUPABASE_PUBLISHABLE_KEY="your-dev-anon-key"

# -----------------------------------------------------------------------------
# SSO / AUTH APP
# -----------------------------------------------------------------------------
# URL of the auth/SSO application
VITE_SSO_URL="http://localhost:5175"

# URL of the superadmin application
VITE_SUPERADMIN_APP_URL="http://localhost:8083"

# -----------------------------------------------------------------------------
# EXTERNAL SERVICES (OPTIONAL for local development)
# -----------------------------------------------------------------------------
# External API URL (if using external services)
# VITE_API_URL=""

# Driver.js product tours (optional). Повторный запуск без once: env true/1 или ?dev_tour=1 в URL
# VITE_DRIVER_DEV_TOUR=false

# -----------------------------------------------------------------------------
# STRIPE PAYMENTS (OPTIONAL)
# -----------------------------------------------------------------------------
# Set to "true" to enable bank card payments via Stripe in the UI
VITE_STRIPE_ENABLED="true"
