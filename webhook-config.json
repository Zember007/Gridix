{
  "port": 8081,
  "host": "localhost",
  "hooks": {
    "nginx-ssl": {
      "execute-command": "/usr/local/bin/auto-ssl-nginx.sh",
      "command-working-directory": "/usr/local/bin",
      "pass-arguments-to-command": [
        {
          "source": "payload",
          "name": "domain"
        }
      ],
      "pass-environment-to-command": [
        {
          "envname": "WEBHOOK_SECRET",
          "source": "payload",
          "name": "webhook_secret"
        }
      ],
      "trigger-rule": {
        "and": [
          {
            "match": {
              "type": "payload-hash-sha1",
              "secret": "your-super-secure-webhook-secret-here",
              "parameter": {
                "source": "header",
                "name": "X-Hub-Signature"
              }
            }
          },
          {
            "match": {
              "type": "value",
              "value": "add",
              "parameter": {
                "source": "payload",
                "name": "action"
              }
            }
          }
        ]
      }
    }
  }
}
